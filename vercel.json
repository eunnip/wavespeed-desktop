{
  "outputDirectory": "out/renderer",
  "functions": {
    "api/health.ts": {
      "includeFiles": "backend/src/**"
    },
    "api/v1/[...route].ts": {
      "includeFiles": "backend/src/**"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api/v1/:path*"
    }
  ]
}
